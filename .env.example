# ── API Keys for OpenCode MCP Servers ──
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Context7 — documentation lookup (https://context7.com)
CONTEXT7_API_KEY=your_context7_api_key_here

# Brave Search — web search (https://brave.com/search/api/)
BRAVE_API_KEY=your_brave_api_key_here

# Firecrawl — web scraping & crawling (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here

# Vercel — MCP integration (https://mcp.vercel.com)
# Create a token at https://vercel.com/account/tokens
VERCEL_ACCESS_TOKEN=your_vercel_access_token_here

# GitHub — issues, PRs, repos (optional, can use GITHUB_TOKEN env var instead)
# GITHUB_TOKEN=ghp_your_github_token_here
